<Window x:Class="Cvicenie_Pokemon.Window_Fight"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cvicenie_Pokemon"
        mc:Ignorable="d"
        Title="Window_Fight" Height="450" Width="800">
    <Grid>
        <Image Margin="488,0,66,178" Source="/Images/Charizard.png" Stretch="Fill"/>
        <Image Margin="0,10,410,203" Source="/Images/Pikachu.png" Stretch="Fill"/>
        <ProgressBar Name="ProgressBar_Hero" HorizontalAlignment="Left" Height="34" Margin="28,257,0,0" VerticalAlignment="Top" Width="302" Foreground="#FF06B018" Maximum="200"/>
        <ProgressBar Name="ProgressBar_Enemy"  HorizontalAlignment="Left" Height="35" Margin="450,256,0,0" VerticalAlignment="Top" Width="323"/>
        <Button Content="Light Attack" HorizontalAlignment="Left" Height="46" Margin="28,296,0,0" VerticalAlignment="Top" Width="86" Click="Button_Click" Background="#FF6FE560"/>
        <Button Content="Medium Attack" HorizontalAlignment="Left" Height="46" Margin="135,296,0,0" VerticalAlignment="Top" Width="88" Click="Button_Click_1" Background="#FFFFF491"/>
        <Button Content="Hight Attack" HorizontalAlignment="Left" Height="46" Margin="244,296,0,0" VerticalAlignment="Top" Width="86" Click="Button_Click_2" Background="#FFFF9480"/>
        <Label Name="Label_GameStatus" Content="" HorizontalAlignment="Center" Height="59" Margin="0,10,0,0" VerticalAlignment="Top" Width="206" FontSize="36" FontWeight="Bold"/>
        <ProgressBar Name="ProgressBar_Energy" HorizontalAlignment="Left" Height="35" Margin="27,365,0,0" VerticalAlignment="Top" Width="302" RenderTransformOrigin="0.5,0.5" Foreground="#FFDEDC01">
            <ProgressBar.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.239"/>
                    <TranslateTransform/>
                </TransformGroup>
            </ProgressBar.RenderTransform>
        </ProgressBar>
    </Grid>
</Window>
